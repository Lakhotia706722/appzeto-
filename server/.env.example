# ================================
# TaskFlow Pro - Server Configuration
# ================================
# SECURITY WARNING: 
# - Never commit this file to version control
# - Use strong, unique values for all secrets
# - Rotate secrets every 90 days
# - Use different secrets for staging/production
# ================================

# ── Server Configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database Configuration ────────────────────────────────────
# MongoDB connection string
# Local: mongodb://localhost:27017/taskflow
# Docker: mongodb://mongo:27017/taskflow
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/taskflow
MONGO_URI=mongodb://localhost:27017/taskflow

# Redis connection string
# Local: redis://localhost:6379
# Docker: redis://redis:6379
# Cloud: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ── JWT Configuration ─────────────────────────────────────────
# CRITICAL: Generate with: openssl rand -hex 32
# Must be at least 32 characters in production
JWT_ACCESS_SECRET=your_access_secret_change_me
JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary Configuration (File Uploads) ───────────────────
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP Configuration (Email Notifications) ──────────────────
# Gmail: smtp.gmail.com (use App Password)
# SendGrid: smtp.sendgrid.net
# AWS SES: email-smtp.region.amazonaws.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Client Configuration ──────────────────────────────────────
# Frontend URL (used for CORS and email links)
# Development: http://localhost:5173
# Production: https://yourdomain.com
CLIENT_URL=http://localhost:5173

